{
  "issuer": "http://localhost:8080",
  "listen": ":8080",
  "key_id": "authbroker-compose-key-1",
  "signing_key_rotation_days": 90,
  "signing_key_retention_days": 30,
  "cookie_secure": false,
  "access_token_ttl_minutes": 15,
  "id_token_ttl_minutes": 15,
  "refresh_token_ttl_days": 1,
  "auth_code_ttl_seconds": 120,
  "session_ttl_hours": 8,
  "admin_groups": ["administrators"],

  "ldap": {
    "url": "ldaps://glauth:389",
    "domain_suffix": "@example.com",
    "base_dn": "dc=glauth,dc=com",
    "user_filter": "(mail={login})",
    "email_attribute": "mail",
    "name_attribute": "cn",
    "groups_attribute": "memberOf",
    "start_tls": false,
    "insecure_skip_verify": true,
    "timeout_seconds": 5
  },

  "mfa": {
    "totp_required": false
  },

  "webauthn": {
    "rp_id": "localhost",
    "rp_display_name": "Go Auth Broker",
    "origins": ["http://localhost:8080", "http://localhost:8091"]
  },

  "app_tokens": [
    {
      "id": "litellm",
      "display_name": "LiteLLM",
      "audience": "litellm",
      "client_id": "litellm",
      "scope": "openid profile email groups",
      "token_ttl_minutes": 480,
      "group_mappings": {
        "app_elk_team10_ingest": "elk-ingest",
        "OU=Demo,DC=glauth,DC=com": "{cn}"
      }
    }
  ],

  "clients": [
    {
      "client_id": "test-web-ui",
      "client_secret_sha256": "90ec7f3296397f5e77371162618cb79734bebd6bffe66d90d739383796a09f5b",
      "redirect_uris": ["http://localhost:8090/callback"],
      "post_logout_redirect_uris": ["http://localhost:8090/"],
      "public": false,
      "require_pkce": true,
      "allowed_scopes": ["openid", "profile", "email", "groups"],
      "allow_offline_access": false,
      "group_mappings": {
        "app_elk_team10_ingest": "elk-ingest",
        "OU=Demo,DC=glauth,DC=com": "{cn}"
      }
    }
  ]
}
